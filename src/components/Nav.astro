---
import { t } from '../i18n/utils'
import { Menu, X } from '@lucide/astro'

interface Props {
  locale: 'en' | 'es' | 'gl'
}
const { locale } = Astro.props

const navLinks = [
  { href: '#about',        label: t(locale, 'nav.about') },
  { href: '#professional', label: t(locale, 'nav.resume') },
  { href: '#portfolio',    label: t(locale, 'nav.portfolio') },
  { href: '#contact',      label: t(locale, 'nav.contact') },
]

const langLinks = [
  { href: '/',    code: 'en', label: t(locale, 'lang.en') },
  { href: '/es/', code: 'es', label: t(locale, 'lang.es') },
  { href: '/gl/', code: 'gl', label: t(locale, 'lang.gl') },
]
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-zinc-900/90 backdrop-blur-sm border-b border-zinc-800">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="#" class="text-white text-lg font-bold hover:text-zinc-300 transition-colors" style="font-family: 'Space Grotesk', sans-serif">
      Cibrán Docampo
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="nav-link text-sm text-zinc-400 hover:text-white transition-colors"
        >
          {link.label}
        </a>
      ))}

      <!-- Language switcher -->
      <div class="flex items-center gap-1 border-l border-zinc-700 pl-5 ml-1">
        {langLinks.map(lang => (
          <a
            href={lang.href}
            data-lang={lang.code}
            class={`text-xs font-medium px-1.5 py-0.5 rounded transition-colors ${
              locale === lang.code
                ? 'text-zinc-200 bg-accent/25 border border-accent/30'
                : 'text-zinc-400 hover:text-zinc-200'
            }`}
          >
            {lang.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="nav-toggle"
      class="md:hidden text-zinc-400 hover:text-white transition-colors p-1"
      aria-label={t(locale, 'nav.open_menu')}
      aria-expanded="false"
    >
      <span id="icon-menu"><Menu size={22} /></span>
      <span id="icon-close" class="hidden"><X size={22} /></span>
    </button>
  </div>
</nav>

<!-- Mobile overlay -->
<div
  id="nav-mobile"
  class="hidden fixed inset-0 top-16 z-40 bg-zinc-900 flex flex-col items-center justify-center gap-8 md:hidden"
>
  {navLinks.map(link => (
    <a
      href={link.href}
      class="nav-mobile-link text-xl font-medium text-zinc-200 hover:text-white transition-colors"
    >
      {link.label}
    </a>
  ))}

  <!-- Language switcher mobile -->
  <div class="flex items-center gap-3 mt-4 border-t border-zinc-800 pt-6">
    {langLinks.map(lang => (
      <a
        href={lang.href}
        data-lang={lang.code}
        class={`text-sm font-medium px-3 py-1.5 rounded transition-colors ${
          locale === lang.code
            ? 'text-zinc-200 bg-accent/25 border border-accent/30'
            : 'text-zinc-400 hover:text-zinc-200'
        }`}
      >
        {lang.label}
      </a>
    ))}
  </div>
</div>

<script is:inline>
  ;(function () {
    const toggle = document.getElementById('nav-toggle')
    const mobile = document.getElementById('nav-mobile')
    const iconMenu = document.getElementById('icon-menu')
    const iconClose = document.getElementById('icon-close')
    let open = false

    function setOpen(state) {
      open = state
      mobile.classList.toggle('hidden', !open)
      iconMenu.classList.toggle('hidden', open)
      iconClose.classList.toggle('hidden', !open)
      toggle.setAttribute('aria-expanded', String(open))
    }

    toggle.addEventListener('click', () => setOpen(!open))

    // Close when a section link is clicked
    document.querySelectorAll('.nav-mobile-link').forEach(function (link) {
      link.addEventListener('click', function () { setOpen(false) })
    })

    // Persist language choice in localStorage
    document.querySelectorAll('[data-lang]').forEach(function (el) {
      el.addEventListener('click', function () {
        localStorage.setItem('lang', el.dataset.lang)
      })
    })
  })()
</script>

<script is:inline>
  ;(function () {
    var sections = ['about', 'professional', 'portfolio', 'contact']

    // Only target desktop nav links to avoid clashing with mobile overlay colours
    var navLinks = {}
    sections.forEach(function (id) {
      navLinks[id] = document.querySelectorAll('.nav-link[href="#' + id + '"]')
    })

    function setActive(id) {
      sections.forEach(function (s) {
        navLinks[s].forEach(function (link) {
          if (s === id) {
            link.classList.add('text-white')
            link.classList.remove('text-zinc-400')
          } else {
            link.classList.remove('text-white')
            link.classList.add('text-zinc-400')
          }
        })
      })
    }

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) setActive(entry.target.id)
        })
      },
      { threshold: 0.3, rootMargin: '-64px 0px 0px 0px' }
    )

    sections.forEach(function (id) {
      var el = document.getElementById(id)
      if (el) observer.observe(el)
    })
  })()
</script>
