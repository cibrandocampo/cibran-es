---
import { t } from '../../i18n/utils'
import { ChevronDown } from '@lucide/astro'
import profile from '../../data/profile.json'

interface Props {
  locale: 'en' | 'es' | 'gl'
}
const { locale } = Astro.props
---

<section id="hero" class="min-h-screen flex items-center bg-zinc-900">
  <div class="max-w-6xl mx-auto px-4 py-20 w-full">
    <div class="flex flex-col-reverse md:flex-row items-center gap-12">

      <!-- Text -->
      <div class="flex-1 text-center md:text-left">
        <p class="text-zinc-400 text-lg mb-3">Hi, I'm</p>
        <h1 class="font-bold text-white leading-none mb-6" style="font-family: 'Space Grotesk', sans-serif">
          <span class="text-5xl md:text-7xl">{profile.firstName}</span>
          <span class="block text-5xl md:text-7xl">{profile.lastName}</span>
        </h1>

        <div class="text-xl md:text-2xl text-zinc-300 mb-10 h-8 flex items-center justify-center md:justify-start">
          <span id="typed-text" aria-live="polite"></span><span class="typed-cursor select-none" aria-hidden="true">|</span>
        </div>

        <!-- Scroll down -->
        <a
          href="#about"
          class="inline-flex flex-col items-center gap-1 text-zinc-500 hover:text-zinc-300 transition-colors animate-bounce"
          aria-label={t(locale, 'hero.scroll_down')}
        >
          <ChevronDown size={28} />
        </a>
      </div>

      <!-- Avatar -->
      <div class="flex-shrink-0">
        <div class="w-44 h-44 md:w-64 md:h-64 rounded-full overflow-hidden border-2 border-zinc-700 ring-4 ring-zinc-800">
          <img
            src="/images/avatar.jpg"
            alt={profile.name}
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .typed-cursor {
    animation: blink 0.7s step-end infinite;
  }
  @keyframes blink {
    50% { opacity: 0; }
  }
</style>

<script is:inline define:vars={{ titles: profile.typedTitles }}>
  ;(function () {
    const el = document.getElementById('typed-text')
    if (!el) return

    let titleIdx = 0
    let charIdx = 0
    let deleting = false
    const TYPING_SPEED = 80
    const DELETING_SPEED = 40
    const PAUSE_MS = 2000

    function tick() {
      const current = titles[titleIdx]
      if (deleting) {
        charIdx--
        el.textContent = current.slice(0, charIdx)
        if (charIdx === 0) {
          deleting = false
          titleIdx = (titleIdx + 1) % titles.length
          setTimeout(tick, 400)
          return
        }
        setTimeout(tick, DELETING_SPEED)
      } else {
        charIdx++
        el.textContent = current.slice(0, charIdx)
        if (charIdx === current.length) {
          deleting = true
          setTimeout(tick, PAUSE_MS)
          return
        }
        setTimeout(tick, TYPING_SPEED)
      }
    }
    setTimeout(tick, 600)
  })()
</script>
