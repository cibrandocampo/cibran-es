---
import { tAll } from '../../i18n/utils'
import Tr from '../ui/Tr.astro'
import SectionTitle from '../ui/SectionTitle.astro'
import FunFact from '../ui/FunFact.astro'
import InterestCard from '../ui/InterestCard.astro'
import profile from '../../data/profile.json'
import funFacts from '../../data/fun-facts.json'
import interests from '../../data/interests.json'
---

<section id="about" class="py-24 bg-zinc-900">
  <div class="max-w-6xl mx-auto px-4 space-y-20">

    <!-- Block 1: Bio -->
    <div>
      <SectionTitle><Tr {...tAll('section.about')} /></SectionTitle>
      <div class="max-w-3xl space-y-4">
        {(['en', 'es', 'gl'] as const).map(lang =>
          profile.bio.long[lang].map((p: string) => (
            <p class={`i18n-${lang} text-zinc-300 leading-relaxed`}>{p}</p>
          ))
        )}
      </div>
    </div>

    <!-- Block 2: It's me -->
    <div>
      <h3 class="text-xs font-medium uppercase tracking-widest text-zinc-500 mb-6">
        <Tr {...tAll('about.itsme_title')} />
      </h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {interests.map(item => (
          <InterestCard
            icon={item.icon}
            name={item.name}
            description={item.description}
          />
        ))}
      </div>
    </div>

    <!-- Block 3: Few numbers -->
    <div>
      <h3 class="text-xs font-medium uppercase tracking-widest text-zinc-500 mb-6">
        <Tr {...tAll('about.facts_title')} />
      </h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {funFacts.map(fact => (
          <FunFact
            emoji={fact.emoji}
            value={fact.value}
            label={fact.label}
            note={fact.note}
          />
        ))}
      </div>
    </div>

  </div>
</section>
