---
interface Props {
  emoji: string
  value: string
  label: string
  note: string
}
const { emoji, value, label, note } = Astro.props
---

<div class="flex flex-col p-5 bg-zinc-800/50 border border-zinc-700/50 rounded-lg gap-1">
  <div class="flex items-center gap-3">
    <span class="text-xl">{emoji}</span>
    <span class="text-2xl font-bold text-accent">{value}</span>
    <span class="text-sm font-medium text-zinc-100">{label}</span>
  </div>
  <div class="text-xs text-zinc-500 leading-snug">{note}</div>
</div>
