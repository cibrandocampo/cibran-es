---
type I18n = { en: string; es: string; gl: string }

interface Props {
  emoji: string
  value: string
  label: I18n
  note: I18n
}
const { emoji, value, label, note } = Astro.props
---

<div class="flex flex-col p-5 bg-zinc-800/50 border border-zinc-700/50 rounded-lg gap-1">
  <div class="flex items-center gap-3">
    <span class="text-xl">{emoji}</span>
    <span class="text-2xl font-bold text-accent">{value}</span>
    <span class="text-sm font-medium text-zinc-100">
      <span class="i18n-en">{label.en}</span><span class="i18n-es">{label.es}</span><span class="i18n-gl">{label.gl}</span>
    </span>
  </div>
  <div class="text-xs text-zinc-500 leading-snug">
    <span class="i18n-en">{note.en}</span><span class="i18n-es">{note.es}</span><span class="i18n-gl">{note.gl}</span>
  </div>
</div>
