---
import { Globe, User } from '@lucide/astro'

interface DockerHub {
  images: string[]
  totalPulls: number
}

interface Project {
  id: string
  title: string
  category: string
  image: string
  logo?: string | null
  description: string
  tags: string[]
  github: string | null
  url: string | null
  urlType?: string | null
  highlight: boolean
  dockerHub: DockerHub | null
}

interface Props {
  project: Project
  pulls?: number
}
const { project, pulls } = Astro.props

const displayPulls = pulls ?? project.dockerHub?.totalPulls ?? 0
const cardLink = project.url ?? project.github ?? null
---

<div class="relative flex flex-col bg-zinc-800 border border-zinc-700/50 rounded-lg overflow-hidden hover:border-zinc-500 transition-colors group">
  <!-- Full-card link overlay (z-0) -->
  {cardLink && (
    <a
      href={cardLink}
      target="_blank"
      rel="noopener noreferrer"
      class="absolute inset-0 z-10"
      aria-label={`Visit ${project.title}`}
    />
  )}

  <!-- Header: screenshot + logo overlay, or centered logo -->
  {project.image ? (
    <div class="relative overflow-hidden" style="aspect-ratio: 16/9;">
      <img
        src={`/${project.image}`}
        alt={project.title}
        class="w-full h-full object-cover"
        loading="lazy"
      />
      {project.logo && (
        <div class="absolute bottom-2 left-2">
          <img
            src={`/${project.logo}`}
            alt={`${project.title} logo`}
            class="w-11 h-11 rounded-md shadow-lg ring-1 ring-white/10"
          />
        </div>
      )}
    </div>
  ) : project.logo ? (
    <div class="relative overflow-hidden flex items-center justify-center" style="aspect-ratio: 16/9; background-color: #05091a;">
      <img
        src={`/${project.logo}`}
        alt={`${project.title} logo`}
        class="w-16 h-16 rounded-2xl shadow-lg"
        loading="lazy"
      />
    </div>
  ) : null}

  <!-- Content -->
  <div class="relative flex flex-col flex-1 p-4 gap-3">
    <h3 class="text-sm font-semibold text-white leading-snug">{project.title}</h3>

    <p class="text-xs text-zinc-400 leading-relaxed flex-1">{project.description}</p>

    <!-- Tags -->
    {project.tags.length > 0 && (
      <div class="flex flex-wrap gap-1">
        {project.tags.map(tag => (
          <span class="text-xs text-zinc-200 bg-accent/25 border border-accent/30 px-2 py-0.5 rounded">
            {tag}
          </span>
        ))}
      </div>
    )}

    <!-- Footer: category | links + docker -->
    <div class="flex items-center justify-between gap-2 pt-1 border-t border-zinc-700/50">
      <span class="text-xs text-brand bg-brand/10 border border-brand/25 px-2 py-0.5 rounded-full flex-shrink-0">
        {project.category}
      </span>

      <div class="flex items-center gap-2">
        {project.github && (
          <a
            href={project.github}
            target="_blank"
            rel="noopener noreferrer"
            class="relative z-20 text-brand hover:text-yellow-300 transition-colors"
            aria-label="GitHub repository"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
            </svg>
          </a>
        )}
        {project.url && (
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="relative z-20 text-brand hover:text-yellow-300 transition-colors"
            aria-label={project.urlType === 'profile' ? 'My profile' : 'Project website'}
          >
            {project.urlType === 'profile' ? <User size={16} /> : <Globe size={16} />}
          </a>
        )}
        {project.dockerHub && (
          <div class="flex items-center gap-1 text-xs text-sky-400">
            <span aria-hidden="true">🐳</span>
            <span>{displayPulls.toLocaleString('en')}</span>
          </div>
        )}
      </div>
    </div>
  </div>
</div>
