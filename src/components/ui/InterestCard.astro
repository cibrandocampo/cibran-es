---
import * as LucideIcons from '@lucide/astro'

type I18n = { en: string; es: string; gl: string }

interface Props {
  icon: string
  name: I18n
  description: I18n
}
const { icon, name, description } = Astro.props

function toPascalCase(s: string): string {
  return s
    .split('-')
    .map(part => part.charAt(0).toUpperCase() + part.slice(1))
    .join('')
}

const IconComponent = (LucideIcons as Record<string, any>)[toPascalCase(icon)]
---

<div class="flex flex-col gap-3 p-5 bg-zinc-800/50 border border-zinc-700/50 rounded-lg">
  <div class="flex items-center gap-3">
    {IconComponent && <IconComponent size={20} class="text-accent flex-shrink-0" />}
    <h3 class="text-sm font-semibold text-white">
      <span class="i18n-en">{name.en}</span><span class="i18n-es">{name.es}</span><span class="i18n-gl">{name.gl}</span>
    </h3>
  </div>
  <p class="text-sm text-zinc-400 leading-relaxed">
    <span class="i18n-en">{description.en}</span><span class="i18n-es">{description.es}</span><span class="i18n-gl">{description.gl}</span>
  </p>
</div>
