---
import { ChevronDown, Globe } from '@lucide/astro'
interface Project {
  title: string
  tagline: string
  tag: string
  url: string | null
  description: string[]
  tags: string[]
}

interface Props {
  period: string
  company: string
  role: string
  projects: Project[]
  open?: boolean
}
const { period, company, role, projects, open = false } = Astro.props
---

<div
  class="accordion-entry border-b border-zinc-700/50"
  data-open={open ? 'true' : 'false'}
>
  <button
    class="accordion-trigger w-full flex items-center justify-between py-5 text-left gap-4 hover:opacity-80 transition-opacity"
    type="button"
  >
    <div class="flex flex-col gap-0.5">
      <span class="text-xs text-accent uppercase tracking-widest">{period}</span>
      <div class="flex items-center gap-2">
        <h3 class="text-base font-semibold text-white">{company}</h3>
        <span class="text-xs font-semibold text-zinc-900 bg-brand px-1.5 py-0.5 rounded-full tabular-nums">
          {projects.length}
        </span>
      </div>
      <span class="text-sm text-zinc-400">{role}</span>
      <div class="accordion-tags-preview flex flex-wrap gap-1 mt-2">
        {projects.map(project => (
          <span class="text-xs text-brand bg-brand/10 border border-brand/25 px-2 py-0.5 rounded-full">
            {project.tag}
          </span>
        ))}
      </div>
    </div>
    <ChevronDown
      size={18}
      class={`chevron flex-shrink-0 text-zinc-400 transition-transform duration-300${open ? ' rotate-180' : ''}`}
    />
  </button>

  <div
    class="accordion-body overflow-hidden transition-all duration-300"
    style={open ? 'max-height: 2000px' : 'max-height: 0'}
  >
    <div class="pb-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
      {projects.map(project => (
        <div class="relative flex flex-col gap-2 p-3 bg-zinc-800/50 border border-zinc-700/30 rounded-lg hover:border-zinc-600 transition-colors group/proj">
          {project.url && (
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="absolute inset-0 z-10 rounded-lg"
              aria-label={`Visit ${project.title}`}
            />
          )}

          <!-- Header: title + category tag -->
          <div class="flex items-start justify-between gap-2">
            <span class="text-sm font-medium text-white leading-snug">{project.title}</span>
            <span class="text-xs text-brand bg-brand/10 border border-brand/25 px-2 py-0.5 rounded-full whitespace-nowrap flex-shrink-0">
              {project.tag}
            </span>
          </div>

          <!-- Tagline -->
          <p class="text-xs text-zinc-400 leading-relaxed">{project.tagline}</p>

          <!-- Description bullets -->
          {project.description && project.description.length > 0 && (
            <ul class="space-y-1">
              {project.description.map(line => (
                <li class="text-xs text-zinc-500 leading-relaxed flex gap-1.5">
                  <span class="text-zinc-600 flex-shrink-0 mt-0.5">›</span>
                  <span>{line}</span>
                </li>
              ))}
            </ul>
          )}

          <!-- Footer: tech tags left, link icon bottom-right -->
          <div class="flex items-end justify-between gap-2 pt-1 mt-auto">
            {project.tags && project.tags.length > 0 ? (
              <div class="flex flex-wrap gap-1">
                {project.tags.map(tag => (
                  <span class="text-xs text-zinc-200 bg-accent/25 border border-accent/30 px-1.5 py-0.5 rounded">
                    {tag}
                  </span>
                ))}
              </div>
            ) : <div />}
            {project.url && (
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="relative z-20 text-brand hover:text-yellow-300 transition-colors flex-shrink-0"
                aria-label={`Visit ${project.title}`}
              >
                <Globe size={13} />
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .accordion-entry[data-open="true"] .accordion-tags-preview {
    display: none;
  }
</style>
