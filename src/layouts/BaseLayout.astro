---
import '../styles/global.css'
import { t } from '../i18n/utils'
import Nav from '../components/Nav.astro'

interface Props {
  locale: 'en' | 'es' | 'gl'
  title?: string
  description?: string
}

const { locale, title, description } = Astro.props
const pageTitle = title ?? t(locale, 'meta.title')
const pageDesc = description ?? t(locale, 'meta.description')

const siteUrl = 'https://cibran.es'

const localePaths: Record<string, string> = { en: '/', es: '/es/', gl: '/gl/' }
const ogLocales: Record<string, string> = { en: 'en_GB', es: 'es_ES', gl: 'gl_ES' }
const canonicalUrl = `${siteUrl}${localePaths[locale]}`
const ogImage = `${siteUrl}/og-image.jpg`

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Cibrán Docampo Piñeiro',
  jobTitle: 'Senior Software Developer',
  url: siteUrl,
  image: `${siteUrl}/og-image.jpg`,
  email: 'hola@cibran.es',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Cangas',
    addressRegion: 'Galicia',
    addressCountry: 'ES',
  },
  sameAs: [
    'https://www.linkedin.com/in/cidocampo/',
    'https://github.com/cibrandocampo',
    'https://hub.docker.com/u/cibrandocampo',
  ],
  knowsAbout: [
    'Python', 'Django', 'Flask', 'Node.js',
    'PostgreSQL', 'AWS', 'Docker', 'Kubernetes',
    'Backend Development', 'Cloud Architecture', 'Data Engineering',
    'Observability', 'FFmpeg', 'IPTV', 'HLS', 'DASH',
  ],
  knowsLanguage: [
    { '@type': 'Language', name: 'Galician' },
    { '@type': 'Language', name: 'Spanish' },
    { '@type': 'Language', name: 'English' },
    { '@type': 'Language', name: 'Portuguese' },
  ],
  alumniOf: [
    {
      '@type': 'EducationalOrganization',
      name: 'Universidad de Vigo',
      description: 'Telecommunication Technical Engineering — Image and Sound (2009–2014)',
    },
    {
      '@type': 'EducationalOrganization',
      name: 'UNIR — La Universidad en Internet',
      description: "Master's Degree in Teacher Training — Technology and IT (2022–2023)",
    },
  ],
  hasCredential: [
    {
      '@type': 'EducationalOccupationalCredential',
      name: 'Scrum Manager Experto',
      credentialCategory: 'certificate',
      recognizedBy: { '@type': 'Organization', name: 'Scrum Manager' },
    },
    {
      '@type': 'EducationalOccupationalCredential',
      name: 'Drone Pilot Certificate A1-A3',
      credentialCategory: 'license',
      recognizedBy: { '@type': 'Organization', name: 'AESA' },
    },
  ],
}

const jsonLdWebsite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  url: siteUrl,
  name: 'Cibrán Docampo',
  author: {
    '@type': 'Person',
    name: 'Cibrán Docampo Piñeiro',
  },
}
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <meta name="author" content="Cibrán Docampo Piñeiro" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <title>{pageTitle}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="en" href={`${siteUrl}/`} />
    <link rel="alternate" hreflang="es" href={`${siteUrl}/es/`} />
    <link rel="alternate" hreflang="gl" href={`${siteUrl}/gl/`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />

    <!-- Open Graph -->
    <meta property="og:type" content="profile" />
    <meta property="og:site_name" content="Cibrán Docampo" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocales[locale]} />
    {Object.entries(ogLocales).filter(([l]) => l !== locale).map(([, loc]) => (
      <meta property="og:locale:alternate" content={loc} />
    ))}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={pageTitle} />
    <meta property="profile:first_name" content="Cibrán" />
    <meta property="profile:last_name" content="Docampo Piñeiro" />
    <meta property="profile:username" content="cibrandocampo" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD — Person -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- JSON-LD — WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebsite)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" sizes="any" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  </head>
  <body class="bg-zinc-900 text-zinc-100 font-sans antialiased pt-16">
    <!-- Language auto-detection (runs once, stores preference in localStorage) -->
    <script is:inline>
      ;(function () {
        const stored = localStorage.getItem('lang')
        if (stored) return
        const langs = (navigator.languages && navigator.languages.length ? Array.from(navigator.languages) : [navigator.language]).map(l => (l || '').toLowerCase())
        let target = 'en'
        for (const lang of langs) {
          if (lang.startsWith('gl')) { target = 'gl'; break }
          if (lang.startsWith('es') || lang.startsWith('ca') || lang.startsWith('eu')) { target = 'es'; break }
        }
        localStorage.setItem('lang', target)
        const path = window.location.pathname
        if (target === 'es' && !path.startsWith('/es')) {
          window.location.replace('/es' + (path === '/' ? '/' : path))
        } else if (target === 'gl' && !path.startsWith('/gl')) {
          window.location.replace('/gl' + (path === '/' ? '/' : path))
        }
      })()
    </script>

    <Nav locale={locale} />
    <slot />
  </body>
</html>
